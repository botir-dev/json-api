# ================================
# APPLICATION
# ================================
NODE_ENV=production
PORT=3000
APP_NAME="Enterprise API"
APP_URL=https://your-app.railway.app

# ================================
# DATABASE (Railway PostgreSQL)
# ================================
DATABASE_URL=postgresql://postgres:MQqFOXuYJrFilzxSxzWAxPbTkbuPtOel@shortline.proxy.rlwy.net:53367/railway

# ================================
# REDIS (Railway Redis or Upstash)
# ================================
REDIS_URL=redis://default:password@host:6379
REDIS_TTL=3600

# ================================
# JWT - CHANGE THESE IN PRODUCTION!
# ================================
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ================================
# LOGGING
# ================================
LOG_LEVEL=info
LOG_PRETTY=false

# ================================
# CORS
# ================================
CORS_ORIGINS=https://your-frontend.vercel.app

# ================================
# MOCK MODE (set false in production)
# ================================
MOCK_MODE=false

# ================================
# FEATURES
# ================================
ENABLE_SWAGGER=true
ENABLE_API_KEYS=true
